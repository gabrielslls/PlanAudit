{
  "$schema": "https://opencode.ai/config.json",
  "model": "volcengine-plan/doubao-seed-code",
  "compaction": {
    "auto": true
  },
  "provider": {
    "volcengine-plan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Volcano Engine",
      "options": {
        "baseURL": "http://127.0.0.1:9000",
        "apiKey": "{env:VOLCENGINE_API_KEY}"
      },
      "models": {
        "ark-code-latest": {
          "name": "ark-code-latest",
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "parameters": {
            "temperature": 0.3,
            "top_p": 0.95
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "doubao-seed-code": {
          "name": "doubao-seed-code",
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "parameters": {
            "temperature": 0.3,
            "top_p": 0.95
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "glm-4.7": {
          "name": "glm-4.7",
          "limit": {
            "context": 200000,
            "output": 8192
          },
          "parameters": {
            "temperature": 0.2,
            "top_p": 0.9
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "deepseek-v3.2": {
          "name": "deepseek-v3.2",
          "limit": {
            "context": 128000,
            "output": 4096
          },
          "parameters": {
            "temperature": 0.3,
            "top_p": 0.95
          }
        },
        "doubao-seed-2.0-code": {
          "name": "doubao-seed-2.0-code",
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "parameters": {
            "temperature": 0.3,
            "top_p": 0.95
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "doubao-seed-2.0-pro": {
          "name": "doubao-seed-2.0-pro",
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "parameters": {
            "temperature": 0.2,
            "top_p": 0.9
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "doubao-seed-2.0-lite": {
          "name": "doubao-seed-2.0-lite",
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "parameters": {
            "temperature": 0.7,
            "top_p": 1.0
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "minimax-m2.5": {
          "name": "minimax-m2.5",
          "limit": {
            "context": 200000,
            "output": 8192
          },
          "parameters": {
            "temperature": 0.2,
            "top_p": 0.9
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "kimi-k2.5": {
          "name": "kimi-k2.5",
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "parameters": {
            "temperature": 0.2,
            "top_p": 0.9
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "autoupdate": false,
  "snapshot": false,
  "plugin": ["oh-my-opencode@latest"],
  "mcp": {}
}
